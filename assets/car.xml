<!-- Car body: kinematically driven by JAX dynamics via mocap_pos/mocap_quat.
     Initial position is overwritten at sim startup from the track's start_pose.
     Root element <mujocoinclude> is stripped by MuJoCo on include. -->
<mujocoinclude>
<body name="car" mocap="true" pos="0 0 0.4">
  <inertial pos="0 0 0" mass="1e-4" diaginertia="1e-9 1e-9 1e-9"/>
  <geom name="car_body" type="box"
        size="1.2 0.6 0.2"
        rgba="0.85 0.2 0.2 1"
        contype="0" conaffinity="0"/>
  <!-- LiDAR site: 0.75m forward, 0.15m above center -->
  <site name="lidar_site"
        pos="0.75 0 0.15"
        size="0.05" type="sphere" rgba="0.2 0.9 0.2 1"/>
</body>
</mujocoinclude>
